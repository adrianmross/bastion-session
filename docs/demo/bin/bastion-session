#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  explain)
    cat <<'JSON'
{
  "host": "my-vps-01",
  "ssh_config": {
    "hostname": "10.0.1.25",
    "user": "cloud-user",
    "proxyjump": "my-bastion"
  },
  "session": {
    "lifecycle": "ACTIVE",
    "expires_in": "26m14s"
  }
}
JSON
    ;;
  session)
    cat <<'JSON'
{
  "ok": true,
  "action": "reused_active_session",
  "target_private_ip": "10.0.1.25",
  "ssh_host": "my-vps-01"
}
JSON
    ;;
  ssh-config)
    cat <<'JSON'
{
  "ok": true,
  "include_path": "~/.ssh/config.d/bastion-session",
  "matching_hosts": ["my-vps-01"],
  "issues": []
}
JSON
    ;;
  *)
    echo "bastion-session demo shim: unsupported command" >&2
    exit 2
    ;;
esac
